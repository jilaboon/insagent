generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Auth & Users
// ============================================================

enum UserRole {
  OWNER
  MANAGER
  AGENT
  OPERATIONS
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      UserRole @default(AGENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedCustomers Customer[]
  tasks             Task[]
  importJobs        ImportJob[]
  auditEntries      AuditEntry[]
  recommendations   Recommendation[] @relation("ReviewedBy")
  assignedQueue     QueueEntry[]     @relation("AssignedQueue")
  customerNotes     CustomerNote[]

  @@map("users")
}

// ============================================================
// Customers
// ============================================================

model Customer {
  id               String   @id @default(uuid())
  israeliId        String   @unique // ת.ז.
  firstName        String
  lastName         String
  address          String?
  phone            String?
  email            String?
  assignedManagerId String?
  assignedManager  User?    @relation(fields: [assignedManagerId], references: [id])
  age              Int?
  dateOfBirth      DateTime?
  maritalStatus    String?
  gender           String?
  lastReviewDate   DateTime?
  lastImportDate   DateTime?
  // Where this customer originated. "OFFICE" = imported via BAFI; the
  // office manages their book. "HAR_HABITUACH_ONLY" = seen in Har HaBituach
  // but no office record in BAFI — a prospect-like record: same shape as
  // other customers (so the rules engine can evaluate them uniformly), but
  // the UI must flag them clearly so רפי can decide whether to onboard.
  source           String?  @default("OFFICE")
  firstSeenInHarHabituachAt DateTime?
  lastHarHabituachImportAt  DateTime?
  // Consent for storing third-party financial data (Misleka XML, future banking).
  // Recorded at import time; a customer with no consent record yet has nulls.
  externalDataConsentAt    DateTime?
  externalDataConsentScope String?      // "MISLEKA_PRODUCTS" | "FULL_360" | "DEMO_INTERNAL"
  externalDataConsentRef   String?      // optional reference to a signed consent doc
  // Snapshot metadata for the CustomerContext propensity model.
  contextComputedAt        DateTime?
  contextCompletenessScore Int?         // 0=BAFI only, 1=+HaR, 2=+Misleka, 3=+banking
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  familyMembers    FamilyMember[]
  policies         Policy[]
  insights         Insight[]
  recommendations  Recommendation[]
  tasks            Task[]
  fieldProvenance  FieldProvenance[]
  importLinks      ImportJobCustomer[]
  messageDrafts    MessageDraft[]
  queueEntries     QueueEntry[]
  notes            CustomerNote[]
  financialProducts CustomerFinancialProduct[]

  @@index([israeliId])
  @@index([assignedManagerId])
  @@index([lastName, firstName])
  @@index([source])
  @@map("customers")
}

// ============================================================
// Customer conversation journal — running log of agent notes
// (calls placed, offers made, return-date commitments, etc).
// Multi-row log (not a single text field) so we preserve history.
// ============================================================

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId, createdAt])
  @@map("customer_notes")
}

enum FamilyMemberSource {
  IMPORTED
  MANUAL
}

model FamilyMember {
  id           String             @id @default(uuid())
  customerId   String
  customer     Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  israeliId    String?
  name         String
  relationship String?
  source       FamilyMemberSource @default(IMPORTED)
  createdAt    DateTime           @default(now())

  @@index([customerId])
  @@map("family_members")
}

// ============================================================
// Insurance Data
// ============================================================

enum PolicyCategory {
  PROPERTY      // רכוש - רכב, דירה, עסק
  HEALTH        // בריאות, סיעוד, תאונות אישיות ופרט
  LIFE          // ביטוח חיים
  PENSION       // פנסיה
  SAVINGS       // חיסכון טהור
  RISK          // סיכון טהור
  PROVIDENT     // קרן השתלמות / גמל
}

enum PolicyStatus {
  ACTIVE        // בתוקף
  PROPOSAL      // הצעה
  CANCELLED     // מבוטל
  EXPIRED       // פג תוקף
  FROZEN        // מוקפאת
  PAID_UP       // מסולקת
  ARREARS       // בפיגור
  UNKNOWN
}

model Policy {
  id              String         @id @default(uuid())
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  policyNumber    String
  insurer         String
  category        PolicyCategory
  subType         String?        // רכב-מקיף, רכב-חובה, דירה, etc.
  status          PolicyStatus   @default(ACTIVE)
  productName     String?        // שם מוצר ביצרן
  startDate       DateTime?
  endDate         DateTime?
  premiumMonthly  Float?
  premiumAnnual   Float?
  accountType     String?        // פרט / שכיר
  employer        String?
  totalDepositsYtd Float?
  lastDeposit     Float?
  redemptionValue Float?
  accumulatedSavings Float?
  // Management fees as percentage. Each policy has at most one of each
  // (אחוז דמי ניהול מצבירה / מפרמיה). Stored directly on Policy instead
  // of a separate table so rule matching becomes a single field check.
  feeOnAccumulationPct Float?
  feeOnPremiumPct Float?
  dataFreshnessDate DateTime?    // נכונות המידע
  importJobId     String?
  importJob       ImportJob?     @relation(fields: [importJobId], references: [id])
  // Source of the policy data. null = created from BAFI/office data;
  // "HAR_HABITUACH" = discovered via Har HaBituach import (= product held
  // outside the office). A policy can start as BAFI and later be confirmed
  // by Har HaBituach — in that case externalSource stays null but the
  // harHabituach*SeenAt timestamps get set.
  externalSource  String?
  harHabituachFirstSeenAt DateTime?
  harHabituachLastSeenAt  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Vehicle-specific
  vehicleYear     Int?
  vehiclePlate    String?
  vehicleModel    String?

  // Property-specific
  propertyAddress String?

  coverages        Coverage[]
  investmentTracks InvestmentTrack[]

  @@unique([customerId, policyNumber, insurer])
  @@index([customerId])
  @@index([category])
  @@index([endDate])
  @@index([insurer])
  @@index([externalSource])
  @@map("policies")
}

model Coverage {
  id            String   @id @default(uuid())
  policyId      String
  policy        Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  name          String   // שם כיסוי ביצרן
  startDate     DateTime?
  endDate       DateTime?
  insuredType   String?  // ראשי / משני
  sumInsuredDeath Float?
  sumInsured    Float?
  cost          Float?

  @@index([policyId])
  @@map("coverages")
}

model InvestmentTrack {
  id            String  @id @default(uuid())
  policyId      String
  policy        Policy  @relation(fields: [policyId], references: [id], onDelete: Cascade)
  name          String
  depositType   String?
  accumulatedAmount Float?
  ytdReturn     Float?

  @@index([policyId])
  @@map("investment_tracks")
}

// ============================================================
// Intelligence
// ============================================================

enum InsightCategory {
  EXPIRING_POLICY
  SINGLE_CATEGORY
  NO_PROPERTY
  NO_HEALTH
  STALE_DATA
  PREMIUM_CONCENTRATION
  NO_RECENT_CONTACT
  FAMILY_NO_COVERAGE
  HIGH_SAVINGS_LOW_PROTECTION
  COVERAGE_GAP
  MANAGEMENT_FEE_HIGH
  CROSS_SELL_OPPORTUNITY
  AGE_MILESTONE
  POLICY_AGE_REVIEW
  DEPOSIT_GAP
  AI_GENERATED
}

enum InsightStatus {
  NEW
  REVIEWED
  DISMISSED
  CONVERTED_TO_RECOMMENDATION
  CONVERTED_TO_TASK
}

model Insight {
  id            String          @id @default(uuid())
  customerId    String
  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category      InsightCategory
  title         String
  summary       String
  explanation   String?
  whyNow        String?         // explicit timing explanation
  urgencyLevel  Int             @default(0) // 0=low, 1=medium, 2=high
  dataFreshness Int             @default(0) // 0=stale, 1=partial, 2=fresh
  profileCompleteness Int       @default(0) // 0=low, 1=medium, 2=high
  evidenceJson  Json?           // source references
  status        InsightStatus   @default(NEW)
  strengthScore Int?            // composite score 1-100 for ranking
  branch        String?         // "LIFE" or "ELEMENTARY"
  generatedBy   String          @default("DETERMINISTIC") // DETERMINISTIC / RULE / AI
  linkedRuleId  String?
  // Inherited from OfficeRule.kind at generation time.
  // "commercial" = money-on-floor sales opportunity
  // "service_tip" = advisory/relationship-building
  kind          String          @default("commercial")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  recommendations Recommendation[]
  messageDrafts   MessageDraft[]
  queueEntriesPrimary QueueEntry[] @relation("PrimaryInsight")

  @@index([customerId])
  @@index([category])
  @@index([status])
  @@index([strengthScore])
  @@index([linkedRuleId])
  @@index([linkedRuleId, status])
  @@map("insights")
}

enum RecommendationType {
  POLICY_RENEWAL
  COVERAGE_GAP_REVIEW
  INACTIVITY_FOLLOWUP
  CROSS_SELL
  DOCUMENT_FOLLOWUP
  PREMIUM_OPTIMIZATION
  FAMILY_PROTECTION_REVIEW
  SERVICE_REVIEW
}

enum RecommendationStatus {
  PENDING
  APPROVED
  REJECTED
  POSTPONED
  CONVERTED_TO_TASK
  EXPIRED
}

model Recommendation {
  id              String               @id @default(uuid())
  customerId      String
  customer        Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  insightId       String?
  insight         Insight?             @relation(fields: [insightId], references: [id])
  type            RecommendationType
  title           String
  shortExplanation String
  fullRationale   String?
  whyNow          String               // explicit timing
  officeRationale String?
  customerRationale String?
  strengthLevel   Int                  @default(1) // 0=low, 1=medium, 2=high
  evidenceJson    Json?
  generatedBy     String               @default("DETERMINISTIC")
  linkedRuleId    String?
  status          RecommendationStatus @default(PENDING)
  reviewerId      String?
  reviewer        User?                @relation("ReviewedBy", fields: [reviewerId], references: [id])
  reviewerNotes   String?
  reviewedAt      DateTime?
  expiresAt       DateTime?
  cooldownUntil   DateTime?            // dedup cooldown
  convertedTaskId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  feedback        RecommendationFeedback[]

  @@index([customerId])
  @@index([status])
  @@index([type])
  @@index([expiresAt])
  @@map("recommendations")
}

enum RejectionReason {
  IRRELEVANT
  DUPLICATE
  WRONG_TIMING
  INSUFFICIENT_EVIDENCE
  WRONG_WORDING
  SENSITIVE
  ALREADY_HANDLED
}

model RecommendationFeedback {
  id                String           @id @default(uuid())
  recommendationId  String
  recommendation    Recommendation   @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  action            String           // approved / rejected / postponed / positive_signal
  rejectionReason   RejectionReason?
  comment           String?
  actorId           String
  createdAt         DateTime         @default(now())

  @@index([recommendationId])
  @@map("recommendation_feedback")
}

// ============================================================
// Tasks
// ============================================================

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id                 String       @id @default(uuid())
  customerId         String?
  customer           Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  linkedRecommendationId String?
  ownerId            String?
  owner              User?        @relation(fields: [ownerId], references: [id])
  title              String
  description        String?
  priority           TaskPriority @default(MEDIUM)
  status             TaskStatus   @default(OPEN)
  dueDate            DateTime?
  completedAt        DateTime?
  source             String?      // recommendation / manual / import
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([ownerId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

// ============================================================
// Data Import
// ============================================================

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

// Typed kind so we don't keep growing string conventions on `fileType`.
// Existing pipelines (BAFI, Har HaBituach) will be backfilled to the
// matching enum values once on migration; new code reads `kind`.
enum ImportKind {
  BAFI_LIFE
  BAFI_ELEMENTARY
  HAR_HABITUACH
  MISLEKA_XML
  BANKING_STATEMENT     // placeholder for Phase 4
  BANKING_OPEN_API      // placeholder for Phase 4
}

model ImportJob {
  id              String       @id @default(uuid())
  fileName        String
  fileType        String       // bafi_html / csv / excel / pdf — legacy free string
  kind            ImportKind?  // typed identity for new imports; null for legacy rows
  filePath        String?      // Supabase storage path
  fileSize        Int?
  status          ImportStatus @default(PENDING)
  operatorId      String
  operator        User         @relation(fields: [operatorId], references: [id])
  totalRows       Int?
  importedRows    Int?
  failedRows      Int?
  newCustomers    Int?
  updatedCustomers Int?
  ambiguousMatches Int?
  errorLog        Json?
  mappingConfig   Json?
  // Per-file metadata for batch imports — Misleka uploads carry multiple
  // files from different providers under one job. Shape:
  //   { files: [{ fileName, fileHash, providerCode, providerName,
  //                xmlVersion, interfaceType, productTypes, executionDate,
  //                encoding, warnings }] }
  metadataJson    Json?
  // Batch-level warnings rolled up across files.
  warnings        Json?
  // Consent recorded at import time. For DEMO_INTERNAL scope, OWNER role
  // can bypass real consent — that path is logged separately.
  consentSource     String?    // "CUSTOMER_VERBAL" | "CUSTOMER_SIGNED" | "AGENT_REPRESENTED" | "DEMO_INTERNAL"
  consentScope      String?    // "MISLEKA_PRODUCTS" | "FULL_360" | "DEMO_INTERNAL"
  consentDate       DateTime?
  consentRecordedBy String?    // operator email
  consentDocRef     String?    // optional reference to signed consent doc
  // Soft-delete marker for per-import rollback. Listing endpoints filter
  // deletedAt IS NULL by default; deleted imports stay queryable for audit.
  deletedAt         DateTime?
  deletedBy         String?    // operator email who initiated rollback
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  policies              Policy[]
  customerLinks         ImportJobCustomer[]
  financialProducts     CustomerFinancialProduct[]
  balanceSnapshots      CustomerBalanceSnapshot[]

  @@index([status])
  @@index([operatorId])
  @@index([kind])
  @@index([deletedAt])
  @@map("import_jobs")
}

model ImportJobCustomer {
  id           String    @id @default(uuid())
  importJobId  String
  importJob    ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  matchType    String    // exact / probable / new
  createdAt    DateTime  @default(now())

  @@unique([importJobId, customerId])
  @@map("import_job_customers")
}

// ============================================================
// InstitutionalProvider — canonical metadata for the financial
// institutions seen in Misleka XML (and later: banks, agencies).
// Replaces the loose `insurer` string field over time.
// ============================================================

model InstitutionalProvider {
  id            String   @id @default(uuid())
  providerCode  String   @unique     // 9-digit Israeli company tax ID
  providerName  String                // canonical Hebrew name
  shortName     String?               // short-form display name
  category      String                // "INSURANCE" | "PENSION" | "BANK" | "AGENCY"
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  financialProducts CustomerFinancialProduct[]

  @@index([category])
  @@map("institutional_providers")
}

// ============================================================
// CustomerFinancialProduct — institutional pension/provident/
// savings/insurance products discovered through Misleka XML.
// Distinct from `Policy` (which models agency-managed insurance).
// Future bank accounts, loans, credit cards follow the same
// per-source pattern (separate tables, unified through
// CustomerContext).
// ============================================================

model CustomerFinancialProduct {
  id                  String   @id @default(uuid())
  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  providerId          String?
  provider            InstitutionalProvider? @relation(fields: [providerId], references: [id])
  importJobId         String?
  importJob           ImportJob? @relation(fields: [importJobId], references: [id])

  source              String   // "MISLEKA_XML" | "MANUAL" | "BANKING_*" (future)
  sourceFileName      String?
  sourceRecordPath    String?  // XPath where this product lives in the source XML

  productTypeCode     String   // SUG-MUTZAR raw code (e.g. "1" / "4" / "6")
  productTypeLabel    String?  // resolved Hebrew label
  interfaceType       String?  // KGM / INP / ING
  planName            String?  // SHEM-TOCHNIT
  policyOrAccountNumber String?  // MISPAR-POLISA-O-HESHBON
  unifiedProductCode  String?  // KIDOD-ACHID (30-digit consolidated code)

  statusCode          String?
  statusLabel         String?
  isActive            Boolean  @default(false)

  joinDate            DateTime?  // TAARICH-HITZTARFUT-MUTZAR
  firstJoinDate       DateTime?  // TAARICH-HITZTARFUT-RISHON
  lastUpdatedDate     DateTime?  // TAARICH-IDKUN-STATUS
  valuationDate       DateTime?  // TAARICH-NECHONUT

  hasLoan             Boolean  @default(false)
  hasArrears          Boolean  @default(false)
  hasExternalCoverage Boolean  @default(false)
  hasBeneficiaries    Boolean  @default(false)
  hasAttorney         Boolean  @default(false)

  employerName        String?  // SHEM-MAASIK
  employerCode        String?  // MPR-MAASIK-BE-YATZRAN

  rawImportantFieldsJson Json?

  // Deterministic identity for idempotent upsert. Computed as SHA-256 of:
  //   customerId | providerCode | policyOrAccountNumber | productTypeCode |
  //   unifiedProductCode | sourceRecordPath
  // Never null. Avoids PostgreSQL's "multiple-nulls-allowed" loophole on
  // composite unique keys.
  sourceStableKey     String   @unique

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  balances            CustomerBalanceSnapshot[]

  @@index([customerId])
  @@index([providerId])
  @@index([source])
  @@index([productTypeCode])
  @@index([importJobId])
  @@map("customer_financial_products")
}

// ============================================================
// CustomerBalanceSnapshot — time-series of balances/contributions
// for a financial product. A product can have multiple snapshots
// per date (one per investment track from PerutMasluleiHashkaa,
// plus product-total roll-ups, plus redemption-value entries).
// ============================================================

model CustomerBalanceSnapshot {
  id                       String   @id @default(uuid())
  productId                String
  product                  CustomerFinancialProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  importJobId              String?
  importJob                ImportJob? @relation(fields: [importJobId], references: [id])
  snapshotDate             DateTime    // TAARICH-NECHONUT or TAARICH-ERECH-TZVIROT

  // Discriminators — together with productId+date these make the row unique.
  snapshotKind             String      // "TRACK_BALANCE" | "PRODUCT_TOTAL" | "REDEMPTION" | "BLOCK"
  trackCode                String?     // KOD-MASLUL when applicable; null for product-wide rows
  trackName                String?     // SHEM-MASLUL

  balanceAmount            Decimal?    @db.Decimal(18, 2)  // SCHUM-TZVIRA-BAMASLUL
  redemptionAmount         Decimal?    @db.Decimal(18, 2)  // BlockItrot / Yitrot
  monthlyContribution      Decimal?    @db.Decimal(14, 2)  // SCHUM-HAFRASHA when monthly
  employeeContribution     Decimal?    @db.Decimal(14, 2)  // SUG-HAFRASHA = 8
  employerContribution     Decimal?    @db.Decimal(14, 2)  // SUG-HAFRASHA = 9
  compensationComponent    Decimal?    @db.Decimal(14, 2)  // pizoy
  ytdReturn                Decimal?    @db.Decimal(8, 4)   // TSUA-NETO-METZUVERET-MITCHILAT-SHANA

  rawJson                  Json?

  createdAt                DateTime @default(now())

  // Per-track + per-kind uniqueness preserves Misleka's per-track detail
  // (a product can have several balances on the same date).
  @@unique([productId, snapshotDate, snapshotKind, trackCode])
  @@index([productId, snapshotDate(sort: Desc)])
  @@map("customer_balance_snapshots")
}

// ============================================================
// Messages
// ============================================================

enum MessageDraftStatus {
  DRAFT
  APPROVED
  SENT
  SKIPPED
}

model MessageDraft {
  id          String             @id @default(uuid())
  customerId  String
  customer    Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  insightId   String?
  insight     Insight?           @relation(fields: [insightId], references: [id])
  body        String             // Hebrew WhatsApp message text
  tone        String?            // professional / warm / urgent
  purpose     String?            // renewal / tip / cross-sell / service
  status         MessageDraftStatus @default(DRAFT)
  generatedBy    String             @default("AI")
  feedbackFlag   String?            // bad_hebrew / bad_content / wrong_tone / good
  feedbackNote   String?            // free text from user
  feedbackAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([customerId])
  @@index([insightId])
  @@index([status])
  @@map("message_drafts")
}

// ============================================================
// Office Rules — Dynamic rule engine
// ============================================================

model OfficeRule {
  id              String   @id @default(uuid())
  title           String   // short title in Hebrew
  body            String   // full rule/message text in Hebrew
  category        String?  // renewal / coverage / savings / general / service
  triggerCondition String? // structured: "age >= 60", "policy_category = LIFE AND policy_age > 3"
  triggerHint     String?  // human-readable: "לקוחות מעל גיל 60"
  source          String   @default("MANUAL") // MANUAL / AI_DATA / AI_KNOWLEDGE
  // "commercial" = data-driven opportunity, money-on-floor (leads a sales call)
  // "service_tip" = data-driven but advisory, relationship-building
  kind            String   @default("commercial")
  // Baseline strength Rafi assigns to the rule itself. Used as the
  // starting score for any insight generated by this rule; context
  // boosts (small-portfolio customer, has external data, etc.) are
  // added on top at generation time.
  baseStrength    Int      @default(60)
  isActive        Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("office_rules")
}

// Keep office_tips table alias for backward compatibility during migration
model OfficeTip {
  id          String   @id @default(uuid())
  title       String
  body        String
  category    String?
  triggerHint String?
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("office_tips")
}

// ============================================================
// Knowledge Base — Industry articles & regulation updates
// ============================================================

model KnowledgeArticle {
  id             String   @id @default(uuid())
  title          String
  content        String   // the pasted text
  source         String?  // URL or "manual"
  summary        String?  // AI-generated summary
  tipsExtracted  Int      @default(0)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("knowledge_articles")
}

// ============================================================
// Daily Action Queue — the main operational object
// ============================================================

enum QueueLane {
  TODAY
  SOON
}

enum QueueStatus {
  PENDING
  COMPLETED
  POSTPONED
  DISMISSED
  BLOCKED
  EXTERNAL
}

enum ReasonCategory {
  URGENT_EXPIRY
  AGE_MILESTONE
  HIGH_VALUE
  COVERAGE_GAP
  COST_OPTIMIZATION
  SERVICE
  CROSS_SELL
}

enum GenerationReason {
  DAILY_REBUILD
  POST_IMPORT
  POST_RULE_CHANGE
  MANUAL_REFRESH
  INCREMENTAL_FILL
}

model QueueEntry {
  id                   String           @id @default(uuid())
  queueDate            DateTime         @db.Date
  lane                 QueueLane
  rank                 Int

  customerId           String
  customer             Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)

  primaryInsightId     String?
  primaryInsight       Insight?         @relation("PrimaryInsight", fields: [primaryInsightId], references: [id])
  supportingInsightIds String[]

  whyTodayReason       String
  reasonCategory       ReasonCategory

  assignedUserId       String?
  assignedUser         User?            @relation("AssignedQueue", fields: [assignedUserId], references: [id])

  generationReason     GenerationReason
  generationVersion    Int              @default(1)
  debugContext         Json?

  status               QueueStatus      @default(PENDING)
  actionedAt           DateTime?
  actionedByUserId     String?
  actionNote           String?
  postponeUntil        DateTime?

  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([queueDate, lane, customerId, assignedUserId])
  @@index([queueDate, lane])
  @@index([customerId])
  @@index([status])
  @@index([assignedUserId, status])
  @@map("queue_entries")
}

// ============================================================
// System Settings — tracks global state
// ============================================================

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ============================================================
// Provenance
// ============================================================

model FieldProvenance {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  entityType    String   // customer / policy / coverage
  entityId      String
  fieldName     String
  value         String?
  sourceFile    String?
  importJobId   String?
  importedAt    DateTime?
  overrideByUserId String?
  overrideAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([customerId])
  @@index([entityType, entityId])
  @@map("field_provenance")
}

// ============================================================
// Audit
// ============================================================

model AuditEntry {
  id          String   @id @default(uuid())
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  entityType  String   // customer / recommendation / task / import / rule / user
  entityId    String?
  action      String   // created / updated / approved / rejected / deleted / imported
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_entries")
}
